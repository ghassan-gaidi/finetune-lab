## Dataset — Agentic Data Mix

This notebook loads from the **best available agentic datasets** and mixes
them into a single training set. All use ShareGPT-style conversations with
tool-calling trajectories and `<think>` reasoning blocks — directly compatible
with DeepHermes-3's training structure.

### Available Datasets

| # | Dataset | Config | Samples | What it teaches |
|---|---------|--------|---------|----------------|
| 1 | `lambda/hermes-agent-reasoning-traces` | kimi | 7,646 | Kimi-K2.5 multi-turn agent traces — `<think>` + `<tool_call>` — reasoning before action |
| 2 | `lambda/hermes-agent-reasoning-traces` | glm-5.1 | 7,055 | GLM-5.1 agent traces, same schema — tool use + recovery |
| 3 | `DJLougen/hermes-agent-traces-filtered` | — | 3,679 | Quality-filtered — deeper reasoning, self-correction, verification patterns |
| 4 | `NousResearch/hermes-function-calling-v1` | func_calling | 8,372 | Multi-turn Hermes FC — JSON tool calls, parameter selection |
| 5 | `NousResearch/hermes-function-calling-v1` | func_calling_singleturn | 1,620 | Single-turn FC — learn tool dispatch syntax |
| 6 | `NousResearch/hermes-function-calling-v1` | json_mode_agentic | 3,500 | Agentic JSON structured output |
| 7 | `glaiveai/glaive-function-calling-v2` | default | 150,000+ | Largest public FC dataset — broad tool coverage |

The **default mix** below prioritises quality agentic reasoning traces
(datasets 1-4). Edit `DATASET_MIX` to add/remove/rerank.

> All datasets are public and pre-loaded in Hugging Face `datasets`.
> **No API key required to download** (only to push the final model).

# ── Code cell 4 ──
from datasets import load_dataset, concatenate_datasets
from unsloth.chat_templates import get_chat_template

# Apply Llama-3 chat template with ShareGPT field mapping
tokenizer = get_chat_template(
    tokenizer,
    chat_template="llama-3",
    mapping={"role": "from", "content": "value",
             "user": "human", "assistant": "gpt"},
)

# ──────────────────────────────────────────────
# Dataset Mix — edit this to change your blend
# ──────────────────────────────────────────────
# Each entry: (hf_path, config_or_None, max_rows_or_0_for_all, weight)
DATASET_MIX = [
    # Primary: full agent reasoning traces with <think> blocks
    ("lambda/hermes-agent-reasoning-traces", "kimi",     0, 1.0),
    ("lambda/hermes-agent-reasoning-traces", "glm-5.1",  0, 1.0),
    # High-quality filtered subset (self-correction + verification)
    ("DJLougen/hermes-agent-traces-filtered", None,      0, 1.5),
    # Multi-turn function calling from Nous
    ("NousResearch/hermes-function-calling-v1", "func_calling", 0, 0.5),
]
# ──────────────────────────────────────────────

def format_sharegpt(examples):
    """Convert ShareGPT 'conversations' → tokenized text."""
    convos = examples["conversations"]
    texts = [
        tokenizer.apply_chat_template(convo, tokenize=False, add_generation_prompt=False)
        for convo in convos
    ]
    return {"text": texts}


def load_and_format(path, config, limit):
    """Load a dataset and format it. Handles ShareGPT + OpenAI schemas."""
    if config:
        raw = load_dataset(path, config, split="train", token=os.environ["HF_TOKEN"])
    else:
        raw = load_dataset(path, split="train", token=os.environ["HF_TOKEN"])

    if limit and limit < len(raw):
        raw = raw.select(range(limit))
        print(f"  {path}/{config or '-'}: {len(raw)} rows")
    else:
        print(f"  {path}/{config or '-'}: {len(raw)} rows")

    # Detect schema
    if "conversations" in raw.column_names:
        return raw.map(format_sharegpt, batched=True)
    elif "messages" in raw.column_names:
        # Some datasets store messages as a serialised list — skip formatting
        return raw.rename_column("messages", "text")
    else:
        raise ValueError(f"Unknown schema for {path}. Columns: {raw.column_names}")


print("=" * 56)
print("  Loading agentic dataset mix")
print("=" * 56)

all_datasets = []
for ds_path, config, limit, weight in DATASET_MIX:
    ds = load_and_format(ds_path, config, limit)
    count = len(ds)
    if weight != 1.0 and count > 0:
        oversample = int(count * weight)
        if oversample > count:
            ds = concatenate_datasets([ds] * (oversample // count + 1))
            ds = ds.select(range(oversample))
            print(f"    ↑ weighted {weight}x → {len(ds)} rows")
    all_datasets.append(ds)

import random
random.shuffle(all_datasets)
dataset = concatenate_datasets(all_datasets)

print(f"\n✅ Total: {len(dataset)} examples across {len(DATASET_MIX)} datasets")
print(f"    Example:\n{dataset[0]['text'][:300]}...")

# ── Markdown cell 7 ──
---
## Train

# ── Code cell 5 ──
from trl import SFTTrainer
from transformers import TrainingArguments

trainer = SFTTrainer(
    model=model,
    tokenizer=tokenizer,
    train_dataset=dataset,
    dataset_text_field="text",
    max_seq_length=max_seq_length,
    dataset_num_proc=2,
    packing=False,
    args=TrainingArguments(
        per_device_train_batch_size=2,         # small batch = low VRAM
        gradient_accumulation_steps=4,          # effective batch = 8
        warmup_steps=5,
        max_steps=60,                            # switch to num_train_epochs=1 for full pass
        learning_rate=2e-4,
        fp16=True,                                # T4 native math
        bf16=False,
        logging_steps=1,
        optim="adamw_8bit",                      # saves ~2 GB VRAM vs 32-bit Adam
        weight_decay=0.01,
        lr_scheduler_type="linear",
        seed=3407,
        output_dir="outputs",
        report_to="none",                         # no wandb/tensorboard login
        save_strategy="steps",
        save_steps=20,
    ),
)

trainer_stats = trainer.train()
print(f"✅ Training complete — {trainer_stats.metrics['train_loss']:.4f} loss")

